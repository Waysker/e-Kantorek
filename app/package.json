{
  "name": "oragh-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "web:build": "expo export --platform web",
    "web:build:pages": "expo export --platform web && node ./scripts/patch-web-dist-for-pages.mjs",
    "attendance:preflight": "node ./scripts/attendance-sheet-preflight.mjs",
    "typecheck": "tsc --noEmit",
    "forum:publish:attendance": "node ./scripts/publish-attendance-sheet-to-supabase.mjs",
    "forum:sync": "node ./scripts/sync-forum-snapshot.mjs",
    "forum:publish:overrides": "node ./scripts/publish-instrument-overrides-to-supabase.mjs",
    "forum:publish": "node ./scripts/publish-snapshot-to-supabase.mjs",
    "forum:sync:publish": "node ./scripts/run-forum-sync-pipeline.mjs"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.57.4",
    "expo": "~55.0.8",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.0",
    "@types/react": "~19.2.2",
    "cheerio": "^1.2.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
