# Client-side (Expo web/mobile read access)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional legacy fallback:
# EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Optional explicit URL for attendance write queue function.
# If omitted, app derives:
#   https://<project-ref>.functions.supabase.co/attendance_write_sheet_first
# from EXPO_PUBLIC_SUPABASE_URL.
# EXPO_PUBLIC_ATTENDANCE_WRITE_FUNCTION_URL=https://<project-ref>.functions.supabase.co/attendance_write_sheet_first
# Optional UI switch for panel writes. Keep disabled while forum is source of truth.
# EXPO_PUBLIC_ATTENDANCE_WRITE_ENABLED=false

# Sync publisher (server-side write access, do not expose in app client)
SUPABASE_URL=
SUPABASE_SECRET_KEY=
# Optional legacy fallback:
# SUPABASE_SERVICE_ROLE_KEY=

# Optional snapshot key override
ORAGH_SNAPSHOT_KEY=forum

# Optional dedicated key for instrument overrides row (falls back to ORAGH_SNAPSHOT_KEY)
ORAGH_INSTRUMENT_OVERRIDES_KEY=forum
