# Client-side (Expo web/mobile read access)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional legacy fallback:
# EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Sync publisher (server-side write access, do not expose in app client)
SUPABASE_URL=
SUPABASE_SECRET_KEY=
# Optional legacy fallback:
# SUPABASE_SERVICE_ROLE_KEY=

# Optional snapshot key override
ORAGH_SNAPSHOT_KEY=forum
