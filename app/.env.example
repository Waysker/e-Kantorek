# Client-side (Expo web/mobile read access)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional legacy fallback:
# EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Optional key used by attendance setup screen (web PoC):
EXPO_PUBLIC_ATTENDANCE_KEY=forum
# Optional key used for forum_instrument_overrides writes from attendance setup screen:
EXPO_PUBLIC_INSTRUMENT_OVERRIDES_KEY=forum

# Sync publisher (server-side write access, do not expose in app client)
SUPABASE_URL=
SUPABASE_SECRET_KEY=
# Optional legacy fallback:
# SUPABASE_SERVICE_ROLE_KEY=

# Optional snapshot key override
ORAGH_SNAPSHOT_KEY=forum
# Optional dedicated key for attendance_sheet_cache row
ORAGH_ATTENDANCE_KEY=forum

# Optional dedicated key for instrument overrides row (falls back to ORAGH_SNAPSHOT_KEY)
ORAGH_INSTRUMENT_OVERRIDES_KEY=forum

# Optional attendance source workbook path for server-side publish scripts
# ORAGH_ATTENDANCE_SOURCE_PATH=../Copy of Obecności 25'-26'.xlsx

# Optional: force overwrite DB overrides when running forum:publish:overrides
# FORUM_SYNC_FORCE_OVERRIDE_PUBLISH=1
