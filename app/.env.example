# Client-side (Expo web/mobile read access)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional legacy fallback:
# EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Optional explicit URL for attendance write queue function.
# If omitted, app derives:
#   https://<project-ref>.functions.supabase.co/attendance_write_sheet_first
# from EXPO_PUBLIC_SUPABASE_URL.
# EXPO_PUBLIC_ATTENDANCE_WRITE_FUNCTION_URL=https://<project-ref>.functions.supabase.co/attendance_write_sheet_first
# Optional UI switch for management attendance writes.
# EXPO_PUBLIC_ATTENDANCE_WRITE_ENABLED=false
# Required for attendance summary panel source-of-truth filter.
# Must point to the reference attendance sheet ID.
# EXPO_PUBLIC_ATTENDANCE_REFERENCE_SHEET_ID=

# Sync publisher (server-side write access, do not expose in app client)
SUPABASE_URL=
SUPABASE_SECRET_KEY=
# Optional legacy fallback:
# SUPABASE_SERVICE_ROLE_KEY=

# Optional snapshot key override
ORAGH_SNAPSHOT_KEY=forum

# Optional dedicated key for instrument overrides row (falls back to ORAGH_SNAPSHOT_KEY)
ORAGH_INSTRUMENT_OVERRIDES_KEY=forum

# Optional smoke test credentials for automated db_first regression check.
# Requires a manager account (section/board/admin).
# SMOKE_TEST_EMAIL=
# SMOKE_TEST_PASSWORD=
# Optional explicit target (must already exist in attendance_entries):
# SMOKE_EVENT_ID=
# SMOKE_MEMBER_ID=
# By default smoke requires explicit target to avoid touching random rows.
# Set true only for ad-hoc fallback:
# SMOKE_ALLOW_AUTO_TARGET=false
# Optional strictness: require export trigger success.
# SMOKE_REQUIRE_EXPORT_TRIGGER_OK=false
